# ─── Supabase ────────────────────────────────────────────────────
# Get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Anthropic (Claude) ──────────────────────────────────────────
# Required for the AI chat feature
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override the default model (defaults to claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── OpenAI (Whisper) ────────────────────────────────────────────
# Optional: only needed for voice transcription fallback
# (Web Speech API is used first; Whisper is the fallback)
# OPENAI_API_KEY=sk-...

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NYAAY
